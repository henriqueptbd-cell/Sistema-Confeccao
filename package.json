  "description": "sistema-confeccao",
  "homepage": "https://github.com/henriqueptbd-cell/Sistema-Confeccao#readme",
  "bugs": {
    "url": "https://github.com/henriqueptbd-cell/Sistema-Confeccao/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/henriqueptbd-cell/Sistema-Confeccao.git"
  },
  "license": "ISC",
  "author": "Henrique",
  "type": "commonjs",
  "main": "server.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "start": "node ./src/server.js",
    "build": "npm install && npm install --prefix client && npm run build --prefix client",
    "dev": "concurrently \"node --watch ./src/server.js\" \"npm run dev --prefix client\"",
    "dev:server": "node --watch ./src/server.js",
    "dev:client": "npm run dev --prefix client"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
